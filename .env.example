# SnapDeploy Environment Variables
# Set these in the SnapDeploy dashboard — do NOT commit .env to git

APP_NAME=Laravel
APP_ENV=production
APP_KEY=         # Leave empty — generated automatically during docker build
APP_DEBUG=false
APP_URL=https://testephp.snapdeploy.app

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=